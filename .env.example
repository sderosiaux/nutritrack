# ─────────────────────────────────────────────────────────────────────────────
# NutriTrack — Environment Variables
# Copy to .env and fill in values before running.
# See docs/self-hosting.md for full configuration guide.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (PostgreSQL 16) ──────────────────────────────────────────────────
# Connection URL for PostgreSQL. In Docker Compose, host is the service name.
DATABASE_URL=postgresql://nutritrack:nutritrack@postgres:5432/nutritrack

# ── Cache & Queue (Redis 7) ───────────────────────────────────────────────────
# Redis URL for BullMQ job queue and session caching.
REDIS_URL=redis://redis:6379

# ── Object Storage (MinIO / S3-compatible) ────────────────────────────────────
# MinIO endpoint — use service name in Docker, or your S3-compatible host.
MINIO_ENDPOINT=minio
# MinIO API port (default 9000)
MINIO_PORT=9000
# MinIO access key (root user)
MINIO_ACCESS_KEY=minioadmin
# MinIO secret key — change this in production!
MINIO_SECRET_KEY=minioadmin
# Bucket name for food photos and user uploads
MINIO_BUCKET=nutritrack
# Set to true if your MinIO instance uses HTTPS
MINIO_USE_SSL=false

# ── Authentication (Better Auth) ──────────────────────────────────────────────
# REQUIRED: Generate with: openssl rand -base64 32
# Must be at least 32 characters. Keep secret!
BETTER_AUTH_SECRET=change-me-to-a-random-32-char-secret

# Public URL of this app (used for auth redirects and email links)
BETTER_AUTH_URL=http://localhost:3000

# ── AI / Vision Provider ──────────────────────────────────────────────────────
# Which vision provider to use for photo food recognition.
# Options: ollama (self-hosted, free), openai (pay-per-use), gemini (free tier)
VISION_PROVIDER=ollama

# Ollama base URL — used when VISION_PROVIDER=ollama
OLLAMA_URL=http://ollama:11434

# OpenAI API key — used when VISION_PROVIDER=openai
OPENAI_API_KEY=

# Google Gemini API key — used when VISION_PROVIDER=gemini
GEMINI_API_KEY=

# ── Email (Nodemailer via SMTP) ───────────────────────────────────────────────
# SMTP server for password reset emails and weekly summaries.
# Leave blank to disable email (password reset will not work).
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Sender address shown in emails
SMTP_FROM=noreply@nutritrack.local

# ── Push Notifications (Web Push) ────────────────────────────────────────────
# VAPID keys for web push notifications.
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── Application ───────────────────────────────────────────────────────────────
# Full public URL of the app (used in client-side code, emails, and CSP headers)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node environment: development | production | test
NODE_ENV=development

# ── USDA FoodData Central (optional) ─────────────────────────────────────────
# Free API key from https://fdc.nal.usda.gov/api-guide.html
# Used for nutritional data lookup beyond the local seed database.
USDA_API_KEY=

# ── Production — PostgreSQL password (used by docker-compose.prod.yml) ────────
# Only needed for production deployment. Change from default!
POSTGRES_PASSWORD=nutritrack_prod

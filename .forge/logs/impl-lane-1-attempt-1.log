ssionFromRequest(c.req.raw)`\n */\nexport async function getSessionFromRequest(req: Request) {\n  return auth.api.getSession({ headers: req.headers });\n}\n"},"caller":{"type":"direct"}}],"stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":0,"cache_read_input_tokens":77047,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":0},"output_tokens":660,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"bb97f10c-f3e9-4d4d-8c90-eca16b368ef0","uuid":"7953df19-d9fc-4f60-8fa3-39cef1179375"}

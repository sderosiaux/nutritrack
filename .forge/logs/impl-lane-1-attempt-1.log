ting guide\"\n  source: \"spec/08-milestones.md:§Milestone 7\"\n  milestone: \"M7\"\n  lane: 13\n  status: \"pending\"\n  test: null\n  commit: null\n\n- id: \"CHK-059\"\n  description: \"OpenAPI spec auto-generation: wire Hono + Zod schema types to @hono/zod-openapi, serve GET /api/openapi.json and Swagger UI at /api/docs\"\n  source: \"spec/05-tech-stack.md:§Developer Experience\"\n  milestone: \"M7\"\n  lane: 13\n  status: \"pending\"\n  test: null\n  commit: null\n","structuredPatch":[{"oldStart":9,"oldLines":8,"newStart":9,"newLines":8,"lines":["   source: \"spec/05-tech-stack.md:§Stack Decision\"","   milestone: \"M0\"","   lane: 1","-  status: \"pending\"","-  test: null","+  status: \"DONE\"","+  test: \"src/__tests__/chk001-scaffold.test.ts:12\"","   commit: null"," "," - id: \"CHK-002\""]},{"oldStart":18,"oldLines":8,"newStart":18,"newLines":8,"lines":["   source: \"spec/05-tech-stack.md:§Infrastructure (Self-hosted)\"","   milestone: \"M0\"","   lane: 1","-  status: \"pending\"","-  test: null","+  status: \"DONE\"","+  test: \"src/__tests__/chk001-scaffold.test.ts:12\"","   commit: null"," "," - id: \"CHK-003\""]},{"oldStart":27,"oldLines":8,"newStart":27,"newLines":8,"lines":["   source: \"spec/02-data-models.md:§Core Models\"","   milestone: \"M0\"","   lane: 1","-  status: \"pending\"","-  test: null","+  status: \"DONE\"","+  test: \"src/__tests__/chk003-schema.test.ts:12\"","   commit: null"," "," - id: \"CHK-004\""]},{"oldStart":36,"oldLines":8,"newStart":36,"newLines":8,"lines":["   source: \"spec/07-api.md:§Auth\"","   milestone: \"M0\"","   lane: 1","-  status: \"pending\"","-  test: null","+  status: \"DONE\"","+  test: \"src/__tests__/chk004-auth.test.ts:11\"","   commit: null"," "," - id: \"CHK-005\""]}],"userModified":false,"replaceAll":false}}
